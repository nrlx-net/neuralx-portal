# ============================================
# NeuralX Portal — Variables de entorno
# Copiar a .env.local y llenar los valores
# ============================================

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=cdac7e2f-e5c5-400a-833e-09c2e5836606
AZURE_AD_TENANT_ID=155d2fca-bfb9-46c0-9ace-05a0d8e17eee
AZURE_AD_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=GENERA_UN_STRING_RANDOM_DE_32_CARACTERES

# API Backend (FastAPI en Azure Functions)
NEXT_PUBLIC_API_URL=https://panel.neuralxglobal.net

# Azure SQL (si se usan API routes locales en Vercel)
AZURE_SQL_SERVER=neuralxnet.database.windows.net
AZURE_SQL_DATABASE=neuralxbank
AZURE_SQL_USER=TU_USUARIO_SQL
AZURE_SQL_PASSWORD=TU_PASSWORD_SQL

# Azure SQL (usado por FastAPI, no por Next.js directo)
# DATABASE_SERVER=neuralxnet.database.windows.net
# DATABASE_NAME=neuralxbank
